# ==============================================================================
# CONFIGURAÇÃO DO BOT ATENDE CAMALEÃO v2.0
# ==============================================================================

# Nome do Bot
BOT_NAME=Vivi

# Porta do servidor
BOT_PORT=3000

# ==============================================================================
# EVOLUTION API (Obrigatório)
# ==============================================================================
EVOLUTION_URL=https://evolution.gestorconecta.com.br
EVOLUTION_API_KEY=sua_chave_evolution_aqui
EVOLUTION_INSTANCE=camaleao

# URL para webhook (seu domínio público)
WEBHOOK_URL=https://seu-dominio.com/webhook

# ==============================================================================
# INTELIGÊNCIA ARTIFICIAL (Opcional - escolha uma ou mais)
# ==============================================================================

# Google Gemini (Recomendado - tem tier grátis)
# Crie sua chave em: https://makersuite.google.com/app/apikey
GOOGLE_AI_API_KEY=

# Anthropic Claude (Alternativa)
# Crie sua chave em: https://console.anthropic.com/
ANTHROPIC_API_KEY=

# OpenAI GPT (Fallback)
# Crie sua chave em: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# ==============================================================================
# API CAMALEÃO (Opcional - para consultas reais de pedidos)
# ==============================================================================
CAMALEAO_API_KEY=oc_a4f6e08fec8e2a64c388daf280aba64b93788206da2caa52a20b84433105e0f9
CAMALEAO_API_URL=https://painel.camaleaocamisas.com.br/api/v1

# ==============================================================================
# REDIS (Opcional - para cache e sessões)
# ==============================================================================
# Se usar Docker Compose, deixe como está
# Se usar Redis externo, mude para seu servidor
REDIS_URL=redis://redis:6379

# ==============================================================================
# AMBIENTE
# ==============================================================================
NODE_ENV=production
LOG_LEVEL=info